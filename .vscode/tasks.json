{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Backend - Dev",
      "type": "shell",
      "command": "make dev",
      "options": {
        "cwd": "${workspaceFolder}/backend"
      },
      "problemMatcher": ["$python"]
    },
    {
      "label": "Frontend - Dev",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}/frontend"
      },
      "problemMatcher": ["$tsc"]
    },
    {
      "label": "API Types",
      "type": "shell",
      "command": "make api-types",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    },
    {
      "label": "Dev - All",
      "dependsOn": ["Backend - Dev", "Frontend - Dev"],
      "dependsOrder": "parallel",
      "problemMatcher": []
    },
    {
      "label": "Setup",
      "type": "shell",
      "command": "make setup",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "close": true
      },
      "problemMatcher": []
    }
  ]
}
